# Dokploy Environment — paste entire file into Dokploy → Compose app → Environment
# Domain: morph.origin4.co
# Phase 1 QR — no WhatsApp. Replace every CHANGE_ME_* before deploy.
# NEVER commit a filled copy; Dokploy writes backend/.env on the server (gitignored).

# =============================================================================
# Frontend build (docker-compose.dokploy.yml build arg)
# =============================================================================
VITE_PUBLIC_APP_ORIGIN=https://morph.origin4.co

# =============================================================================
# Django — general
# =============================================================================
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_50_PLUS_CHARS
DJANGO_ADMIN_URL=CHANGE_ME_random_admin_path/
DJANGO_ALLOWED_HOSTS=morph.origin4.co,www.morph.origin4.co
DJANGO_READ_DOT_ENV_FILE=False

# =============================================================================
# Django — security / HTTPS (same-origin SPA + API)
# =============================================================================
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_CSRF_TRUSTED_ORIGINS=https://morph.origin4.co,https://www.morph.origin4.co
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True

# Never enable in production
DJANGO_CRM_OPEN_PERMISSIONS=False
DJANGO_ACCOUNT_ALLOW_REGISTRATION=False
DJANGO_ADMIN_FORCE_ALLAUTH=False

# =============================================================================
# Postgres (compose service: postgres)
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kotak
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD
CONN_MAX_AGE=60

# Optional single URL (entrypoint also builds from POSTGRES_* above)
# DATABASE_URL=postgres://CHANGE_ME_DB_USER:CHANGE_ME_LONG_RANDOM_DB_PASSWORD@postgres:5432/kotak

# =============================================================================
# Redis / Celery — Phase 1: no worker
# =============================================================================
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_EAGER_PROPAGATES=True

# =============================================================================
# Gunicorn
# =============================================================================
WEB_CONCURRENCY=2

# =============================================================================
# AWS S3 media — prefer EC2 instance role; leave keys empty if role attached
# =============================================================================
DJANGO_AWS_ACCESS_KEY_ID=
DJANGO_AWS_SECRET_ACCESS_KEY=
DJANGO_AWS_STORAGE_BUCKET_NAME=doughandjoe-media-prod
DJANGO_AWS_S3_REGION_NAME=ap-south-1
DJANGO_AWS_S3_CUSTOM_DOMAIN=d24m4yvlxpismq.cloudfront.net
DJANGO_AWS_S3_MAX_MEMORY_SIZE=100000000

# =============================================================================
# Email (optional Phase 1 — leave blank or configure SMTP later)
# =============================================================================
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_SERVER_EMAIL=
DJANGO_DEFAULT_FROM_EMAIL=Kotak <noreply@morph.origin4.co>
DJANGO_EMAIL_SUBJECT_PREFIX=[Kotak]

# =============================================================================
# API / throttles / docs
# =============================================================================
DJANGO_CHECK_IN_THROTTLE=40/hour
DJANGO_SPECTACULAR_SERVER_URL=https://morph.origin4.co
DJANGO_SPECTACULAR_CONTACT_EMAIL=you@example.com

# =============================================================================
# CRM defaults
# =============================================================================
CRM_INACTIVE_VISIT_DAYS=90
DEFAULT_GOOGLE_REVIEW_LINK=
FEEDBACK_PROMPT_DELAY_SECONDS=1800

# =============================================================================
# Phase 1 OFF — background removal (optional Phase 2)
# =============================================================================
MENU_BG_REMOVAL_URL=
REMOVEBG_API_KEY=

# =============================================================================
# Phase 1 OFF — SMS OTP (leave empty; QR check-in does not need OTP)
# =============================================================================
SMS_API_KEY=
SMS_SENDER_ID=
SMS_TEMPLATE_ID=
SMS_OTP_EXPIRY_SECONDS=300

# =============================================================================
# Phase 1 OFF — WhatsApp (intentionally omitted; defaults to disabled in code)
# =============================================================================
